# ============================================================
# FreeAssetFilter .gitignore
# ============================================================
# 策略：只保留 Python 源码 + 运行时必备 DLL/EXE/.pyd，
# 忽略所有需要单独编译的源文件（Rust/C++）和构建缓存。
# 其他人克隆后可直接运行，无需本地编译。
# ============================================================

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Runtime data (user-specific, regenerated on launch) ---
data/
config/

# --- IDE & editor files ---
.vscode/
.idea/
*.swp
*.swo
*~
.trae/
.deepseek/
.kagent/

# --- OS files ---
.DS_Store
Thumbs.db

# --- Logs & temp files ---
*.log
*.tmp
*.temp

# --- Test & coverage artifacts ---
.pytest_cache/
test_results/
.coverage
coverage.xml
htmlcov/
*.cache
.icon_cache/
tests/gui/screenshots/

# --- Build artifacts (PyInstaller, Nuitka) ---
build/
dist/
*.spec
nuitka-crash-report.xml

# --- Dotfiles (agent workspaces, code index) ---
.*

# --- Design/markdown notes (not source code) ---
*.cube
*.md

# --- Backup & refactor notes ---
*备份*
*backup*
FIX_SUMMARY.md
EXIT_BLOCK_FIX_SUMMARY.md

# --- Test/demo scripts ---
test_*.py
!tests/

# ============================================================
# CORE/ — only keep runtime essentials, ignore build sources
# ============================================================

# native/src/ — Rust source (NOT needed for runtime clone)
freeassetfilter/core/native/src/color_extractor_rust/
freeassetfilter/core/native/src/thumbnail_rust/
# But keep: compiled .pyd and VCOMP140.DLL (runtime essential)
!freeassetfilter/core/native/src/cpp_color_extractor/*.pyd
!freeassetfilter/core/native/src/cpp_color_extractor/libwinpthread-1.dll
!freeassetfilter/core/native/src/cpp_lut_preview/__init__.py
!freeassetfilter/core/native/src/cpp_lut_preview/*.pyd
!freeassetfilter/core/native/src/cpp_lut_preview/VCOMP140.DLL
# Keep: src/__init__.py (so cpp_lut_preview is importable via package)
!freeassetfilter/core/native/src/__init__.py

# C++ build scripts & sources (NOT needed at runtime)
freeassetfilter/core/native/src/cpp_color_extractor/setup.py
freeassetfilter/core/native/src/cpp_lut_preview/setup.py
freeassetfilter/core/native/src/cpp_lut_preview/setup_mingw.py
freeassetfilter/core/native/src/cpp_lut_preview/lut_preview.cpp
freeassetfilter/core/native/src/cpp_lut_preview/build/

# native/bin/ — ALL runtime DLLs/EXEs are tracked (nothing to ignore here)
# Rust build caches (when building from source)
target/
