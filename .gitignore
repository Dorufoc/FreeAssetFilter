# ============================================================
# FreeAssetFilter .gitignore
# ============================================================
# 策略：跟踪所有源码（Python + C++ + Rust），
# 忽略构建中间产物（target/、build/、__pycache__/ 等）。
# 预编译的 .pyd/.dll 也跟踪，方便直接运行。
# ============================================================

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Runtime data (user-specific, regenerated on launch) ---
data/
config/

# --- IDE & editor files ---
.vscode/
.idea/
*.swp
*.swo
*~
.trae/
.deepseek/
.kagent/

# --- OS files ---
.DS_Store
Thumbs.db

# --- Logs & temp files ---
*.log
*.tmp
*.temp

# --- Test & coverage artifacts ---
.pytest_cache/
test_results/
.coverage
coverage.xml
htmlcov/
*.cache
.icon_cache/
tests/gui/screenshots/

# --- Build artifacts (PyInstaller, Nuitka) ---
build/
dist/
*.spec
nuitka-crash-report.xml

# --- Dotfiles (agent workspaces, code index) ---
.*

# --- Design/markdown notes (not source code) ---
*.cube
*.md

# --- Backup & refactor notes ---
*备份*
*backup*
FIX_SUMMARY.md
EXIT_BLOCK_FIX_SUMMARY.md

# --- Test/demo scripts ---
test_*.py
!tests/

# ============================================================
# CORE/NATIVE/ — track source code, ignore build intermediates
# ============================================================

# Rust build cache (target/ is entirely reproducible)
freeassetfilter/core/native/src/color_extractor_rust/target/
freeassetfilter/core/native/src/thumbnail_rust/target/

# C++ build directory (msvc .obj, .lib, .exp intermediate files)
freeassetfilter/core/native/src/cpp_lut_preview/build/
